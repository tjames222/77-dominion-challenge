{
  "name": "77-dominion-challenge",
  "private": true,
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "node --test src/static/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed --project=chromium-functional",
    "test:e2e:update": "playwright test --update-snapshots=all",
    "test:quality": "pnpm test && pnpm build && pnpm test:e2e"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "@vitejs/plugin-vue": "latest",
    "@youversion/platform-core": "^2.2.0",
    "lucide-vue-next": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vue": "latest",
    "vue-tsc": "latest"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "npm": "^11.18.0",
    "supabase": "^2.109.0",
    "wrangler": "^4.107.0"
  }
}
