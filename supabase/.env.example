# Supabase injects these values in deployed Edge Functions. For local `functions
# serve`, copy this file to `supabase/.env.local` and use values from
# `pnpm exec supabase status`.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=REPLACE_WITH_LOCAL_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_LOCAL_SERVICE_ROLE_KEY

# Use Stripe test-mode credentials locally. Automated contract tests stub all
# provider calls and never require real credentials.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_MEMBERSHIP_PRICE_ID=price_REPLACE_ME

# Only trusted application origins belong here. Comma-separate exact origins.
PUBLIC_SITE_URL=http://127.0.0.1:5173
PUBLIC_ALLOWED_SITE_URLS=http://localhost:5173,http://127.0.0.1:5173
CLOUDFLARE_PAGES_PROJECT_HOST=77-dominion-challenge.pages.dev

# Server-only integration runtime. Generate a random worker value of at least
# 32 characters and one 32-byte base64 AES key. Never expose these as VITE_*
# values or commit real provider credentials.
INTEGRATION_WORKER_SECRET=REPLACE_WITH_RANDOM_32_PLUS_CHARACTER_VALUE
INTEGRATION_CREDENTIAL_KEYS={"1":"REPLACE_WITH_BASE64_32_BYTE_KEY"}
